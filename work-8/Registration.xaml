<Window x:Class="work_8.Registration"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:work_8"
        mc:Ignorable="d"
        Title="Регистрация" Height="700" Width="800" WindowStartupLocation="CenterScreen">
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <StackPanel Margin="150,0,150,0"  VerticalAlignment="Center" Grid.ColumnSpan="2" >
            <Label Content="Регистрация" HorizontalAlignment="Center" FontSize="36" FontFamily="Cooper Black" Foreground="#FF000060"/>
            <Label Content="Имя" FontSize="22" FontFamily="Cooper Black" Foreground="#FF8AB5EA"/>
            <TextBox x:Name="name1" FontSize="22"/>
            <Label Content="Фамилия" FontSize="22" FontFamily="Cooper Black" Foreground="#FF8AB5EA"/>
            <TextBox x:Name="lastname1" FontSize="22"/>
            <Label Content="Отчество (необзательно)" FontSize="22" FontFamily="Cooper Black" Foreground="#FF8AB5EA"/>
            <TextBox x:Name="middlename1" FontSize="22"/>
            <Label Content="Номер телефона" FontSize="22" FontFamily="Cooper Black" Foreground="#FF8AB5EA"/>
            <TextBox x:Name="phone1" FontSize="22"/>
            <Label Content="Логин" FontSize="22" FontFamily="Cooper Black" Foreground="#FF8AB5EA"/>
            <TextBox x:Name="login2" FontSize="22" />
            <Label Content="Роль" FontSize="22" FontFamily="Cooper Black" Foreground="#FF8AB5EA"/>
            <ComboBox x:Name="roles"/>
            <Button Content="Регистрация" Margin="0,30, 0, 0" Height="30" Background="#FFA6D7E5" FontFamily="Cooper Black" Foreground="#FFFFD966" FontSize="22" BorderBrush="White" Click="Button_Click"></Button>
            <Image Source="/Рисунок1.png" Width="120" Margin="10"/>
        </StackPanel>
    </Grid>
</Window>
