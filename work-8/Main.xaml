<Window x:Class="work_8.Main"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:work_8"
        mc:Ignorable="d"
        Title="Главная" Height="700" Width="850" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2.5*" x:Name="boo"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0"  Orientation="Vertical">
            <Label Content="Недавние резюме" Foreground="#FF000060" FontSize="20" FontFamily="Cooper Black" Margin="10"/>
            <StackPanel Margin="15" Height="130" Background="#FFE9F4F7">
                <Label Content="Резюме !!!!!!!!!!!!!!!!!!!!" Foreground="#FF000060" FontSize="16" FontFamily="Cooper Black" Margin="4"/>
                <Label Content="Резюме информация важная" Foreground="#FF86ACDB" FontSize="14" FontFamily="Cooper Black" Margin="2"/>
            </StackPanel>
            </StackPanel>
        <StackPanel Grid.Column="1" Background="#FFE9F4F7" >
            <Button Content="Создать резюме" Height="30" Width="170" Margin="20, 20, 20, 0" Foreground="#FF000060" BorderBrush="White" Background="#FF8AB5EA" FontSize="14" FontFamily="Cooper Black"></Button>
            <Button Height="50" Width="170" Margin="20, 20, 20, 0" Foreground="#FF000060" BorderBrush="White" Background="#FF8AB5EA" FontSize="14" FontFamily="Cooper Black" >
                <TextBlock TextAlignment="Center">
                    Зарегистрировать <LineBreak/>
                    пользователя
                </TextBlock>
            </Button>
        </StackPanel>
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="5*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="1" Orientation="Vertical">
                <Button Content="О программе" Width="170" Margin="20, 20, 20, 0" Background="White" BorderBrush="White" Foreground="#FF000060" FontFamily="Cooper Black"/>
                <Button Content="Выход" Width="170" Margin="20, 20, 20, 0" Background="White" BorderBrush="White" Foreground="#FF000060" FontFamily="Cooper Black" Click="Button_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
